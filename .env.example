# Скопируйте в .env и заполните:  cp .env.example .env
# Либо запустите scripts/install_linux.sh — поможет интерактивно.

# --- Telegram-бот (обязательно для telegram_bot.py) ---
# TELEGRAM_BOT_TOKEN=

# --- Admin (Telegram ID администратора — получает заявки, управляет доступом) ---
# Узнать свой ID: отправьте /start боту @userinfobot
# ADMIN_CHAT_ID=обязательно_заполнить
# ADMIN_USER_ID=обязательно_заполнить (ID аккаунта админа для уведомлений)

# Контактные данные админа для новых пользователей (показываются при выборе плана)
# Формат: @username или t.me/username или email
# ADMIN_CONTACT_INFO=@your_telegram

# ALLOW_ALL_USERS=1 (раскомментировать ТОЛЬКО для локальной разработки/отладки)

# --- MAX мессенджер (дублирование уведомлений) ---
# Получить токен: @MasterBot в MAX → /newbot
# MAX_BOT_TOKEN=
# MAX_CHAT_ID=
# MAX_NOTIFY=1

# --- Finnhub: новости US, макро-календарь, онлайн US, WS (опционально) ---
# FINNHUB_API_KEY=

# --- Massive (ex-Polygon.io): котировки US, исторические свечи, новости (опционально) ---
# Free tier: 5 req/min, задержка 15 мин. Paid: real-time, больше лимитов.
# Ключ Polygon.io работает на massive.com (тот же сервис после ребрендинга)
# POLYGON_API_KEY=

# --- Т-Инвестиции (Т-Банк): вторая котировка для .ME рядом с MOEX (опционально) ---
# См. docs/TINKOFF.md и https://developer.tbank.ru/invest/sdk/python_sdk/faq_python/
# pip install -r requirements-tbank.txt
# TINKOFF_INVEST_TOKEN=
# Доп. запрос свечей для VWAP/POC (1=да, 0=нет; см. docs/TINKOFF.md)
# SSA_TBANK_VOLUME=1

# --- LLM Sentiment и Learning ---
# Провайдер: "ollama" (локально, самостоятельно) | "ollama_cloud" (официальный cloud API)
# LLM_PROVIDER=ollama_cloud

# Локальная Ollama (если LLM_PROVIDER=ollama; пользователь поднимает сам)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:1.5b

# Ollama Cloud (официальный cloud API от Ollama; рекомендуется, чтобы не грузить сервер)
# OLLAMA_CLOUD_API_KEY=
# OLLAMA_CLOUD_MODEL=qwen2.5:1.5b

# LLM_SENTIMENT=1
# LLM_CACHE_TTL=3600
# LLM_LEARNING=1
# LLM_LEARNING_MIN=20

# --- Kronos Foundation Model (optional, disabled by default) ---
# Install deps: pip install -r requirements-kronos.txt
# KRONOS_ENABLED=0
# KRONOS_MODEL=NeoQuasar/Kronos-base
# KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base
# KRONOS_DEVICE=              # cuda / mps / cpu / empty for auto
# KRONOS_PRED_LEN=5
# KRONOS_MAX_CONTEXT=512
# KRONOS_WEIGHT=0.15          # additive blending weight in engine scoring
# KRONOS_MAX_PREDICT_SECS=18  # hard timeout to avoid blocking Telegram bot

# --- API layer (FastAPI) ---
# API_RATE_LIMIT_PER_MIN=30
# API_SECRET_KEY=ваш_секретный_ключ_для_аутентификации
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# --- Database (PostgreSQL) ---
# DATABASE_URL=postgresql://ssa:ssa_secret@localhost:5432/stock_signals
# POSTGRES_PASSWORD=ssa_secret

# --- Redis (cache + rate limiter + Celery queue) ---
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Данные бота и логи ---
# STOCK_SIGNAL_DATA=/var/lib/stock_signal_analyzer
# SSA_SIGNAL_LOG=/var/lib/stock_signal_analyzer/signals.jsonl

# --- Уведомления «вне списка» ---
# NOTIFY_INTERVAL_SEC=3600
# OUTSIDE_SCAN_MAX=120
# NOTIFY_MIN_TIER=
