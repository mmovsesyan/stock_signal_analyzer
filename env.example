# Переменные окружения для Docker Compose
# Скопируйте этот файл в .env и заполните значения

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# API ключи (опционально)
FINNHUB_API_KEY=your_finnhub_key_here

# Интервал автосбора сигналов (в секундах)
# 14400 = 4 часа (рекомендуется)
# 3600 = 1 час (агрессивно)
# 28800 = 8 часов (консервативно)
COLLECT_INTERVAL_SEC=14400

# Интервал уведомлений о сильных сигналах (в секундах)
NOTIFY_INTERVAL_SEC=3600

# Минимальный класс для уведомлений (A, B, или C)
NOTIFY_MIN_TIER=A
